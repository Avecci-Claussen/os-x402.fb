{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"]
  },
  "include": [
    "src/sdk/**/*.ts",
    "src/core/types.ts",
    "src/core/scheme.ts",
    "src/core/fb.ts",
    "src/core/unisat.ts",
    "src/core/psbt-verify.ts",
    "src/config.ts"
  ]
}
