{
  "name": "os-x402",
  "version": "0.3.0",
  "type": "module",
  "description": "Open x402 pay-per-call payment rail for Fractal Bitcoin (FB) — non-custodial, agent-native. Provider SDK + self-hostable facilitator.",
  "license": "MIT",
  "author": "The Lonely Bit (thelonelybit.org)",
  "homepage": "https://github.com/Avecci-Claussen/os-x402.fb",
  "repository": { "type": "git", "url": "https://github.com/Avecci-Claussen/os-x402.fb.git" },
  "keywords": ["x402", "fractal-bitcoin", "fractal", "bitcoin", "payments", "agents", "micropayments", "non-custodial"],
  "main": "./dist/sdk/index.js",
  "types": "./dist/sdk/index.d.ts",
  "exports": {
    ".": { "types": "./dist/sdk/index.d.ts", "import": "./dist/sdk/index.js" },
    "./sdk": { "types": "./dist/sdk/index.d.ts", "import": "./dist/sdk/index.js" }
  },
  "files": ["dist", "README.md", "LICENSE", "SPEC.md", "agent-kit"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "facilitator": "tsx src/facilitator/server.ts",
    "demo": "tsx src/examples/demo-server.ts",
    "dev-stack": "tsx src/e2e/dev-stack.ts",
    "e2e": "tsx src/e2e/full.ts",
    "e2e:ai": "tsx src/e2e/ai.ts",
    "agent:demo": "tsx src/examples/agent-demo.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.7"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.10",
    "bcryptjs": "^2.4.3",
    "bip32": "^4.0.0",
    "bip322-js": "^3.0.0",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^6.1.6",
    "bitcoinjs-message": "^2.2.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "ecpair": "^2.1.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0",
    "tiny-secp256k1": "^2.2.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.0"
  }
}
